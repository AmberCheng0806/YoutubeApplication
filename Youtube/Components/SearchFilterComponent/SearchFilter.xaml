<UserControl x:Class="Youtube.Components.SearchFilterComponent.SearchFilter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Youtube.Components.SearchFilterComponent"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- CheckBox 樣式 -->
        <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Border"
                                    Width="18"
                                    Height="18"
                                    Background="#272727"
                                    BorderBrush="#606060"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    Margin="0,0,8,0">
                                <Path x:Name="CheckMark"
                                      Data="M0,5 L5,10 L15,0"
                                      Stroke="#3F51B5"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"
                                      Margin="2"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="Background" Value="#1A237E"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3F51B5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3F51B5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton 樣式 -->
        <Style x:Key="FilterRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Border"
                                    Width="18"
                                    Height="18"
                                    Background="#272727"
                                    BorderBrush="#606060"
                                    BorderThickness="2"
                                    CornerRadius="9"
                                    Margin="0,0,8,0">
                                <Ellipse x:Name="InnerCircle"
                                         Width="8"
                                         Height="8"
                                         Fill="#3F51B5"
                                         Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="Background" Value="#1A237E"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3F51B5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3F51B5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 標題樣式 -->
        <Style x:Key="FilterTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 應用按鈕樣式 -->
        <Style x:Key="ApplyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5C6BC0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#303F9F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#181818" 
            CornerRadius="12" 
            Padding="20"
            Margin="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 類型 -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,40,0">
                <TextBlock Text="類型" Style="{StaticResource FilterTitleStyle}"/>
                <StackPanel Orientation="Vertical">
                    <ItemsControl ItemsSource="{Binding Types}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                        IsChecked="{Binding IsChecked}"
                                        Margin="0,0,0,10"
                                        Command="{Binding DataContext.CheckCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Style="{StaticResource FilterCheckBoxStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- 片長 -->
            <StackPanel Grid.Column="1"
                        Orientation="Vertical" 
                        Margin="0,0,40,0" 
                        Visibility="{Binding FilterVisibility}">
                <TextBlock Text="片長" Style="{StaticResource FilterTitleStyle}"/>
                <StackPanel Orientation="Vertical">
                    <ItemsControl ItemsSource="{Binding Durations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding DisplayName}"
                                           IsChecked="{Binding IsChecked}"
                                           GroupName="Durations"
                                           Style="{StaticResource FilterRadioButtonStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- 上傳日期 -->
            <StackPanel Grid.Column="2"
                        Orientation="Vertical" 
                        Margin="0,0,40,0" 
                        Visibility="{Binding FilterVisibility}">
                <TextBlock Text="上傳日期" Style="{StaticResource FilterTitleStyle}"/>
                <StackPanel Orientation="Vertical">
                    <ItemsControl ItemsSource="{Binding PublishedDates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding DisplayName}"
                                           IsChecked="{Binding IsChecked}"
                                           GroupName="PublishedDates"
                                           Style="{StaticResource FilterRadioButtonStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- 種類 - 改用 ScrollViewer 包裹 -->
            <StackPanel Grid.Column="3"
                        Orientation="Vertical" 
                        Margin="0,0,20,0" 
                        Visibility="{Binding FilterVisibility}">
                <TextBlock Text="種類" Style="{StaticResource FilterTitleStyle}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Disabled"
                             MaxHeight="120"
                             MinWidth="250">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" MaxWidth="500"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding DisplayName}"
                                           IsChecked="{Binding IsChecked}"
                                           GroupName="Categories"
                                           Style="{StaticResource FilterRadioButtonStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- 確定按鈕 -->
            <Button Grid.Column="4"
                    Content="✓ 套用篩選" 
                    Command="{Binding ApplyCommand}"
                    Style="{StaticResource ApplyButtonStyle}"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,0"/>
        </Grid>
    </Border>
</UserControl>

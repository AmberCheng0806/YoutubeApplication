<UserControl
    x:Class="Youtube.Components.ComboBoxComponent.ComboBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Youtube.Components.ComboBoxComponent"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ComboBox
        Background="#121212"
        BorderBrush="#3A3A3A"
        BorderThickness="1"
        DisplayMemberPath="DisplayName"
        FontSize="13"
        Foreground="#121212"
        IsEditable="True"
        IsReadOnly="True"
        ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ItemsSource}"
        SelectedValue="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=SelectedValue, Mode=TwoWay}"
        SelectedValuePath="Key">
        <ComboBox.Template>
            <ControlTemplate TargetType="ComboBox">
                <Grid>
                    <ToggleButton
                        x:Name="ToggleButton"
                        Height="42"
                        Background="#121212"
                        BorderThickness="1"
                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                    <Path
                                        Margin="0,0,12,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 4 4 L 8 0 Z"
                                        Fill="White" />
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <TextBlock
                        Margin="12,0,36,0"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI, Microsoft JhengHei UI, 微軟正黑體"
                        FontSize="13"
                        Foreground="#CCCCCC"
                        IsHitTestVisible="False"
                        Text="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource TemplatedParent}}" />

                    <Popup
                        x:Name="PART_Popup"
                        AllowsTransparency="True"
                        Focusable="False"
                        IsOpen="{TemplateBinding IsDropDownOpen}"
                        Placement="Bottom"
                        PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                        PopupAnimation="Slide"
                        StaysOpen="False">
                        <Border
                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="#2D2D30"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </ComboBox.Template>
        <ComboBox.Style>
            <Style TargetType="ComboBox">
                <Setter Property="FontFamily" Value="Segoe UI, Microsoft JhengHei UI, 微軟正黑體" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="#CCCCCC" />
                <Setter Property="Background" Value="#121212" />
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="FontFamily" Value="Segoe UI, Microsoft JhengHei UI, 微軟正黑體" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Foreground" Value="#CCCCCC" />
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border
                                            x:Name="itemBorder"
                                            Padding="{TemplateBinding Padding}"
                                            Background="#121212">
                                            <TextBlock Foreground="#CCCCCC" Text="{Binding DisplayName}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="itemBorder" Property="Background" Value="#3A3A3A" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="itemBorder" Property="Background" Value="#3F51B5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>
        </ComboBox.Style>
    </ComboBox>
</UserControl>

<UserControl
    x:Class="Youtube.Components.CommentComponent.Comment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Reply="clr-namespace:Youtube.Components.ReplyCommentComponent"
    xmlns:converter="clr-namespace:Youtube.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="clr-namespace:Youtube.Utility"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Youtube.Components.CommentComponent"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converter:TimeAgoConverter x:Key="TimeAgoConverter" />
        <converter:InverseEditVisibilityConverter x:Key="InverseEditVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  圓形頭像  -->
        <Ellipse
            Grid.Column="0"
            Width="36"
            Height="36"
            Margin="0,2,10,0"
            VerticalAlignment="Top">
            <Ellipse.Fill>
                <ImageBrush ImageSource="{Binding AuthorImg}" Stretch="UniformToFill" />
            </Ellipse.Fill>
        </Ellipse>

        <!--  留言主體  -->
        <StackPanel Grid.Column="1" Orientation="Vertical">

            <!--  作者名稱 + 時間 + 選單按鈕  -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#CCCCCC"
                    Text="{Binding AuthorName}" />
                <TextBlock
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="#666666">
                    <Run Text="{Binding PublishedAt, Converter={StaticResource TimeAgoConverter}}" />
                    <Run>
                        <Run.Style>
                            <Style TargetType="Run">
                                <Setter Property="Text" Value="" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                        <Setter Property="Text" Value=" (已編輯)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Run.Style>
                    </Run>
                </TextBlock>

                <ToggleButton
                    x:Name="editCommentBtn"
                    Grid.Column="3"
                    Width="26"
                    Height="26"
                    VerticalAlignment="Center"
                    BorderThickness="0"
                    Content="⋮"
                    Visibility="{Binding EditBtnVisibility}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#666666" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            x:Name="border"
                                            Width="26"
                                            Height="26"
                                            Background="Transparent"
                                            CornerRadius="13">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#222222" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#222222" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Popup
                    IsOpen="{Binding IsChecked, ElementName=editCommentBtn}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=editCommentBtn}"
                    StaysOpen="False">
                    <Border
                        MinWidth="130"
                        Background="#282828"
                        BorderBrush="#3A3A3A"
                        BorderThickness="0.5"
                        CornerRadius="8">
                        <StackPanel Orientation="Vertical">
                            <Button
                                Padding="14,10"
                                BorderThickness="0"
                                Command="{Binding EditModeCommand}"
                                Content="✏ 編輯留言"
                                Foreground="#CCCCCC">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="border"
                                                        Padding="14,10"
                                                        Background="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#333333" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Separator
                                Height="0.5"
                                Margin="10,0"
                                Background="#3A3A3A" />

                            <Button
                                BorderThickness="0"
                                Command="{Binding DataContext.DeleteCommentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="border"
                                                        Padding="14,10"
                                                        Background="Transparent">
                                                        <TextBlock Foreground="#FF4E4E" Text="🗑 刪除留言" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#2E1C1C" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <!--  留言內容  -->
            <TextBlock
                Margin="0,0,0,8"
                helper:TextBlockHelper.HtmlText="{Binding CommentText}"
                FontSize="13"
                Foreground="#CCCCCC"
                LineHeight="19"
                TextWrapping="Wrap"
                Visibility="{Binding EditingModeVisibility, Converter={StaticResource InverseEditVisibilityConverter}}" />

            <!--  編輯模式輸入區塊  -->
            <StackPanel Margin="0,0,0,8" Visibility="{Binding EditingModeVisibility}">
                <TextBox
                    Padding="10,8"
                    Background="#121212"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1"
                    CaretBrush="#CCCCCC"
                    FontSize="13"
                    Foreground="#CCCCCC"
                    SelectionBrush="#3F51B5"
                    Text="{Binding EditedCommentText, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="FontFamily" Value="Segoe UI, Microsoft JhengHei UI, 微軟正黑體" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border
                                            x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#AAAAAA" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!--  儲存 / 取消按鈕列  -->
                <StackPanel
                    Margin="0,8,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Border
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Background="Transparent"
                        CornerRadius="18"
                        Cursor="Hand">
                        <TextBlock
                            FontSize="13"
                            Foreground="#AAAAAA"
                            Text="取消">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding CancelEditModeCommand}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBlock>
                    </Border>
                    <Border
                        Padding="12,6"
                        Background="#3F51B5"
                        CornerRadius="18"
                        Cursor="Hand">
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Text="儲存">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding DataContext.EditCommentCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!--  互動按鈕列  -->
            <StackPanel Cursor="" Orientation="Horizontal">

                <!--  按讚按鈕  -->
                <Border
                    Margin="0,0,6,0"
                    Padding="10,4"
                    CornerRadius="14"
                    Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#272727" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                    <Setter Property="Background" Value="#3F51B5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#AAAAAA" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="👍 " />
                            <Run Text="{Binding LikeCount}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  倒讚按鈕  -->
                <Border
                    Margin="0,0,6,0"
                    Padding="10,4"
                    Background="#272727"
                    CornerRadius="14"
                    Cursor="Hand">
                    <TextBlock
                        FontSize="12"
                        Foreground="#AAAAAA"
                        Text="👎" />
                </Border>

                <!--  回覆按鈕  -->
                <Border
                    Padding="10,4"
                    Background="Transparent"
                    CornerRadius="14"
                    Cursor="Hand"
                    Visibility="{Binding EditingModeVisibility, Converter={StaticResource InverseEditVisibilityConverter}}">
                    <TextBlock
                        FontSize="12"
                        Foreground="#AAAAAA"
                        Text="回覆">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding ReplyCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!--  回覆的ReplyComment usercontrol  -->
            <Border Margin="0,15,0,0" Visibility="{Binding ReplyCommentVisibility}">
                <Reply:ReplyComment
                    CancelCommand="{Binding DataContext.CancelReplyCommentsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Command="{Binding DataContext.AddReplyCommentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                    ParentId="{Binding DataContext.Id, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Border>
            <!--  顯示該留言有幾則回覆  -->
            <Border Visibility="{Binding ReplyCommentCountVisibility}">
                <TextBlock>
                    <Run Text="{Binding ReplyCount}" />
                    <Run Text="則回覆" />
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseLeftButtonUp">
                            <!--<i:InvokeCommandAction Command="{Binding ShowReplyCommentsCommand}" />-->
                            <i:InvokeCommandAction Command="{Binding DataContext.ShowReplyCommentsCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </TextBlock>
            </Border>
            <!--  該留言的子留言  -->
            <Border Visibility="{Binding ReplyCommentsCollectionVisibility}">
                <ItemsControl ItemsSource="{Binding ReplyCommentItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:Comment />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
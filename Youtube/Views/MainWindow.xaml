<Window x:Class="Youtube.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Youtube.Views"
        mc:Ignorable="d"
        xmlns:video="clr-namespace:Youtube.Components.VideoCardComponent"
        xmlns:filter="clr-namespace:Youtube.Components.SearchFilterComponent"
        xmlns:page="clr-namespace:Youtube.Components.PaginationComponent"
        Title="YouTube Search" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F">

    <Window.Resources>
        <!-- 最簡單的搜尋框樣式 - 不使用 Template，直接設定屬性 -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F51B5"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#5C6BC0"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#5C6BC0"/>
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 搜尋按鈕樣式 -->
        <Style x:Key="SearchButtonStyle" TargetType="ButtonBase">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5C6BC0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#303F9F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 滾動條樣式 -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" 
                                           IsDirectionReversed="True"
                                           Width="8"
                                           HorizontalAlignment="Center">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Background" Value="#606060"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="4"
                                                                            Width="8"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#909090"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter Property="Background" Value="#B0B0B0"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 標題列 -->
        <Border Grid.Row="0" Background="#0F0F0F" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12,2.5 L2,8.5 L2,16 L12,22 L22,16 L22,8.5 Z M10,18 L10,12 L16,15 Z" 
                          Fill="#FF0000" 
                          Width="32" 
                          Height="32" 
                          Stretch="Uniform"
                          Margin="0,0,12,0"/>
                    <TextBlock Text="YouTube Search" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 搜尋列 -->
                <Grid Grid.Column="1" MaxWidth="700" HorizontalAlignment="Center" Margin="40,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <!-- 使用最簡單的 TextBox，帶有 Watermark -->
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="44"
                                 x:Name="SearchTextBox"/>

                        <!-- Placeholder 文字 -->
                        <TextBlock Text="搜尋影片、頻道或播放清單..."
                                   Foreground="#808080"
                                   FontSize="16"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="1"
                            Content="🔍 搜尋"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource SearchButtonStyle}"
                            Height="44"
                            Margin="12,0,0,0"/>

                    <ToggleButton  Grid.Column="2"
                             Content="☰ 篩選"
                             Name="FilterToggleButton"
                             Style="{StaticResource SearchButtonStyle}"
                             Margin="12,0,0,0" Height="44" VerticalAlignment="Top"/>

                    <Popup IsOpen="{Binding IsChecked, ElementName=FilterToggleButton}"
                           StaysOpen="False"
                            Placement="Center"
                            VerticalOffset="-220"
                            PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                           PopupAnimation="Slide">

                        <Border Background="#1F1F1F" 
                                BorderBrush="#3F51B5" 
                                BorderThickness="1" 
                                CornerRadius="4"
                                Padding="10">
                            <filter:SearchFilter Command="{Binding DataContext.SearchConditionCommand,RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <!-- 分隔線 -->
        <Border Grid.Row="1" Height="1" Background="#303030"/>

        <!-- 篩選器和內容區 -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}"/>
            </ScrollViewer.Resources>

            <StackPanel>
                <!-- 影片容器 -->
                <ItemsControl x:Name="VideoContainer" 
                              ItemsSource="{Binding VideoCardContexts}"
                              Padding="24,24,24,40"
                              Background="#0F0F0F">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <video:VideoCard Margin="0,0,16,24"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel>
                    <page:Pagination></page:Pagination>
                </StackPanel>

            </StackPanel>

        </ScrollViewer>
    </Grid>
</Window>

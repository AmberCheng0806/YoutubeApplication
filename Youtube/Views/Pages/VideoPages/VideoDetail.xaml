<Page
    x:Class="Youtube.Views.Pages.VideoPages.VideoDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Comment="clr-namespace:Youtube.Components.CommentComponent"
    xmlns:Playlist="clr-namespace:Youtube.Components.PlayListComponent"
    xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="clr-namespace:Youtube.Utility"
    xmlns:local="clr-namespace:Youtube.Views.Pages.VideoPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:replycommentcomponent="clr-namespace:Youtube.Components.ReplyCommentComponent"
    Title="VideoDetail"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="#0F0F0F"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  現代化按鈕樣式  -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#272727" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F3F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4F4F4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  ToggleButton 樣式 (儲存按鈕專用)  -->
        <Style x:Key="SaveToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#272727" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    FontSize="14"
                                    Text="💾" />
                                <TextBlock
                                    FontSize="14"
                                    Foreground="White"
                                    Text="儲存" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F3F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4F4F4F" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#3F51B5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  訂閱按鈕樣式 - 帶狀態變化  -->
        <Style x:Key="SubscribeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CC0000" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!--  未訂閱狀態 (紅色)  -->
                <DataTrigger Binding="{Binding IsSubscript}" Value="False">
                    <Setter Property="Background" Value="#CC0000" />
                </DataTrigger>
                <!--  已訂閱狀態 (灰色)  -->
                <DataTrigger Binding="{Binding IsSubscript}" Value="True">
                    <Setter Property="Background" Value="#272727" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  資訊文字樣式  -->
        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <!--  標題文字樣式  -->
        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="26" />
        </Style>

        <!--  頻道名稱樣式  -->
        <Style x:Key="ChannelNameStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  描述文字樣式  -->
        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
        </Style>

        <!--  滾動條樣式  -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track
                                        x:Name="PART_Track"
                                        Width="8"
                                        HorizontalAlignment="Center"
                                        IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Background" Value="#606060" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border
                                                                        Width="8"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="4" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#909090" />
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter Property="Background" Value="#B0B0B0" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  左側上方:影片播放器 (固定,不滾動)  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="24,20,12,0"
            Background="#000000"
            ClipToBounds="True"
            CornerRadius="12">
            <Wpf:WebView2
                x:Name="webView"
                Height="500"
                helper:WebView2Helper.VideoID="{Binding VideoId}" />
        </Border>

        <!--  左側下方:影片資訊 (只有這裡可滾動)  -->
        <ScrollViewer
            Grid.Row="1"
            Grid.Column="0"
            Margin="24,20,12,20"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  影片標題  -->
                <TextBlock
                    Margin="0,0,0,16"
                    Style="{StaticResource TitleTextStyle}"
                    Text="{Binding VideoTitle}" />

                <!--  影片資訊和互動按鈕  -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  頻道資訊  -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!--  頻道頭像  -->
                        <Ellipse
                            Width="40"
                            Height="40"
                            Margin="0,0,12,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource ChannelNameStyle}" Text="{Binding ChannelTitle}" />
                        </StackPanel>

                        <!--  訂閱按鈕 - 根據 IsSubscript 改變顏色  -->
                        <Button
                            Margin="16,0,0,0"
                            Command="{Binding SubscriptCommand}"
                            Content="{Binding SubcriptionText}"
                            Style="{StaticResource SubscribeButtonStyle}" />
                    </StackPanel>

                    <!--  互動按鈕組  -->
                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <!--  喜歡/不喜歡  -->
                        <Border
                            Margin="0,0,8,0"
                            Background="#272727"
                            CornerRadius="18">
                            <StackPanel Orientation="Horizontal">
                                <!--  Like 按鈕  -->
                                <Border
                                    Padding="16,10,12,10"
                                    CornerRadius="18,0,0,18"
                                    Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <!--  Hover 效果  -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3F3F3F" />
                                                </Trigger>
                                                <!--  已點讚:藍色背景  -->
                                                <DataTrigger Binding="{Binding RateText}" Value="like">
                                                    <Setter Property="Background" Value="#3F51B5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding LikeCommand}" MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <TextBlock FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#AAAAAA" />
                                                <Style.Triggers>
                                                    <!--  已點讚:白色文字  -->
                                                    <DataTrigger Binding="{Binding RateText}" Value="like">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="👍 " />
                                        <Run Text="{Binding LikeCount}" />
                                    </TextBlock>
                                </Border>

                                <Border
                                    Width="1"
                                    Margin="0,8"
                                    Background="#3F3F3F" />

                                <!--  Dislike 按鈕  -->
                                <Border
                                    Padding="12,10,16,10"
                                    CornerRadius="0,18,18,0"
                                    Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <!--  Hover 效果  -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3F3F3F" />
                                                </Trigger>
                                                <!--  已點踩:藍色背景  -->
                                                <DataTrigger Binding="{Binding RateText}" Value="dislike">
                                                    <Setter Property="Background" Value="#3F51B5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding DisLikeCommand}" MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <TextBlock FontSize="14" Text="👎">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#AAAAAA" />
                                                <Style.Triggers>
                                                    <!--  已點踩:白色文字  -->
                                                    <DataTrigger Binding="{Binding RateText}" Value="dislike">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!--  分享按鈕  -->
                        <Button Content="↗️ 分享" Style="{StaticResource ActionButtonStyle}" />

                        <!--  儲存按鈕  -->
                        <!--<Button Content="💾 儲存"
                               Style="{StaticResource ActionButtonStyle}"/>-->

                        <!--  儲存按鈕  -->
                        <ToggleButton x:Name="playlistBtn" Style="{StaticResource SaveToggleButtonStyle}" />

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsChecked, ElementName=playlistBtn}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=playlistBtn}"
                            PopupAnimation="Fade"
                            StaysOpen="False">
                            <Border
                                Margin="0,8,0,0"
                                Padding="0"
                                Background="#1F1F1F"
                                BorderBrush="#3F51B5"
                                BorderThickness="2"
                                CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="10"
                                        Opacity="0.5"
                                        ShadowDepth="3"
                                        Color="Black" />
                                </Border.Effect>

                                <StackPanel MinWidth="280" MaxWidth="400">
                                    <!--  標題列  -->
                                    <Border
                                        Padding="16,12"
                                        Background="#272727"
                                        CornerRadius="8,8,0,0">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="儲存至播放清單" />
                                    </Border>

                                    <!--  播放清單列表  -->
                                    <ScrollViewer
                                        MaxHeight="300"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsControl Margin="8" ItemsSource="{Binding Playlists}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Playlist:PlayList Margin="0,4" Command="{Binding DataContext.SavePlaylistCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!--  底部提示  -->
                                    <Border
                                        Padding="16,10"
                                        Background="#272727"
                                        BorderBrush="#3F3F3F"
                                        BorderThickness="0,1,0,0"
                                        CornerRadius="0,0,8,8">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="#AAAAAA"
                                            Text="點擊可切換播放清單"
                                            TextAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>

                <!--  分隔線  -->
                <Border
                    Height="1"
                    Margin="0,0,0,16"
                    Background="#303030" />

                <!--  影片描述區域  -->
                <Border
                    Padding="16"
                    Background="#272727"
                    CornerRadius="12">
                    <StackPanel>
                        <!--  觀看次數和發布時間  -->
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBlock Style="{StaticResource InfoTextStyle}">
                                <Run Text="{Binding ViewCount, StringFormat='{}{0:N0}'}" />
                                <Run Text="次觀看" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource InfoTextStyle}" Text="{Binding PublishedAt, StringFormat='yyyy/MM/dd'}" />
                        </StackPanel>

                        <!--  影片描述  -->
                        <TextBlock Style="{StaticResource DescriptionTextStyle}" Text="{Binding VideoDescription}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  右側：評論區  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            Padding="16,20"
            Background="#0F0F0F"
            BorderBrush="#303030"
            BorderThickness="1,0,0,0">

            <StackPanel>
                <!--  標題  -->
                <TextBlock
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#AAAAAA"
                    Text="評論區" />

                <!--  撰寫留言區塊  -->
                <replycommentcomponent:ReplyComment CancelCommand="{Binding DataContext.ClearTopReplyCommentTextCommand, RelativeSource={RelativeSource AncestorType=Page}}" Command="{Binding DataContext.AddCommentCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                <!--<Border
                    Margin="0,0,0,16"
                    Padding="14"
                    Background="#1A1A1A"
                    CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                -->
                <!--  使用者頭像  -->
                <!--
                        <Ellipse
                            Grid.Column="0"
                            Width="36"
                            Height="36"
                            Margin="0,0,10,0"
                            VerticalAlignment="Top">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ChannelImg}" Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>

                -->
                <!--  輸入欄位 + 送出按鈕  -->
                <!--
                        <StackPanel Grid.Column="1">
                            <TextBox
                                MinHeight="28"
                                Padding="0,4,0,6"
                                AcceptsReturn="True"
                                Background="Transparent"
                                BorderBrush="#303030"
                                BorderThickness="0,0,0,1.5"
                                CaretBrush="White"
                                FontSize="14"
                                Foreground="#CCCCCC"
                                Text="{Binding CommentText, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                -->
                <!--  placeholder 效果可透過 Behavior 或 Tag 實作  -->
                <!--
                                        <Setter Property="Tag" Value="新增評論…" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <StackPanel
                                Margin="0,10,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Padding="12,6"
                                    Background="Transparent"
                                    BorderBrush="#3F3F3F"
                                    BorderThickness="1"
                                    Content="取消"
                                    Cursor="Hand"
                                    FontSize="13"
                                    Foreground="#AAAAAA">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="18">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#272727" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#3F3F3F" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button
                                    Padding="16,6"
                                    Background="#3F51B5"
                                    BorderThickness="0"
                                    Command="{Binding AddCommentCommand}"
                                    Content="留言"
                                    Cursor="Hand"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Foreground="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>-->

                <!--  留言數量  -->
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="#CCCCCC">
                    <Run Text="{Binding TotalComments}" />
                    <Run Text=" 則留言" />
                </TextBlock>

                <!--  分隔線  -->
                <Border
                    Height="1"
                    Margin="0,0,0,12"
                    Background="#303030" />

                <!--  留言列表  -->
                <ScrollViewer
                    MaxHeight="700"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Comments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Comment:Comment />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  空狀態  -->
                        <TextBlock
                            Margin="0,24,0,0"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="#555555"
                            Text="目前還未有評論"
                            Visibility="{Binding NoCommentsVisibility}" />
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Page>
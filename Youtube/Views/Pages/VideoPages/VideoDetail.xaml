<Page xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"  x:Class="Youtube.Views.Pages.VideoPages.VideoDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Youtube.Views.Pages.VideoPages"
      xmlns:helper="clr-namespace:Youtube.Utility"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="VideoDetail">

    <Grid>
        <Wpf:WebView2 x:Name="webView"  helper:WebView2Helper.VideoID="{Binding VideoId}" />
    </Grid>
</Page>

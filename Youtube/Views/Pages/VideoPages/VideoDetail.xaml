<Page xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"  
      x:Class="Youtube.Views.Pages.VideoPages.VideoDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Youtube.Views.Pages.VideoPages"
      xmlns:helper="clr-namespace:Youtube.Utility"
      xmlns:Playlist="clr-namespace:Youtube.Components.PlayListComponent"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#0F0F0F"
      Title="VideoDetail">

    <Page.Resources>
        <!-- 現代化按鈕樣式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#272727"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F3F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ToggleButton 樣式 (儲存按鈕專用) -->
        <Style x:Key="SaveToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#272727"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="儲存" FontSize="14" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F3F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#3F51B5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 訂閱按鈕樣式 - 帶狀態變化 -->
        <Style x:Key="SubscribeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 未訂閱狀態 (紅色) -->
                <DataTrigger Binding="{Binding IsSubscript}" Value="False">
                    <Setter Property="Background" Value="#CC0000"/>
                </DataTrigger>
                <!-- 已訂閱狀態 (灰色) -->
                <DataTrigger Binding="{Binding IsSubscript}" Value="True">
                    <Setter Property="Background" Value="#272727"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 資訊文字樣式 -->
        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <!-- 標題文字樣式 -->
        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="26"/>
        </Style>

        <!-- 頻道名稱樣式 -->
        <Style x:Key="ChannelNameStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 描述文字樣式 -->
        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- 滾動條樣式 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" 
                                           IsDirectionReversed="True"
                                           Width="8"
                                           HorizontalAlignment="Center">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Background" Value="#606060"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="4"
                                                                            Width="8"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#909090"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter Property="Background" Value="#B0B0B0"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 左側上方:影片播放器 (固定,不滾動) -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="#000000" 
                CornerRadius="12"
                ClipToBounds="True"
                Margin="24,20,12,0">
            <Wpf:WebView2 x:Name="webView"  
                         helper:WebView2Helper.VideoID="{Binding VideoId}"
                         Height="500"/>
        </Border>

        <!-- 左側下方:影片資訊 (只有這裡可滾動) -->
        <ScrollViewer Grid.Row="1" Grid.Column="0"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Margin="24,20,12,20">
            <StackPanel>
                <!-- 影片標題 -->
                <TextBlock Text="{Binding VideoTitle}"
                          Style="{StaticResource TitleTextStyle}"
                          Margin="0,0,0,16"/>

                <!-- 影片資訊和互動按鈕 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 頻道資訊 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 頻道頭像 -->
                        <Ellipse Width="40"
                                 Height="40"
                                 Margin="0,0,12,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ImageUrl}"
                                            Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ChannelTitle}"
                                      Style="{StaticResource ChannelNameStyle}"/>
                        </StackPanel>

                        <!-- 訂閱按鈕 - 根據 IsSubscript 改變顏色 -->
                        <Button Content="{Binding SubcriptionText}" 
                                Command="{Binding SubscriptCommand}"
                                Style="{StaticResource SubscribeButtonStyle}"
                                Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- 互動按鈕組 -->
                    <StackPanel Grid.Column="2" 
                               Orientation="Horizontal"
                               HorizontalAlignment="Right">
                        <!-- 喜歡/不喜歡 -->
                        <Border Background="#272727" 
                                CornerRadius="18"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <!-- Like 按鈕 -->
                                <Border CornerRadius="18,0,0,18"
                                       Padding="16,10,12,10"
                                       Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <!-- Hover 效果 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3F3F3F"/>
                                                </Trigger>
                                                <!-- 已點讚:藍色背景 -->
                                                <DataTrigger Binding="{Binding RateText}" Value="like">
                                                    <Setter Property="Background" Value="#3F51B5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding LikeCommand}" MouseAction="LeftClick"/>
                                    </Border.InputBindings>
                                    <TextBlock FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                                <Style.Triggers>
                                                    <!-- 已點讚:白色文字 -->
                                                    <DataTrigger Binding="{Binding RateText}" Value="like">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="👍 "/>
                                        <Run Text="{Binding LikeCount}"/>
                                    </TextBlock>
                                </Border>

                                <Border Width="1" 
                                        Background="#3F3F3F"
                                        Margin="0,8"/>

                                <!-- Dislike 按鈕 -->
                                <Border CornerRadius="0,18,18,0"
                                       Padding="12,10,16,10"
                                       Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <!-- Hover 效果 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3F3F3F"/>
                                                </Trigger>
                                                <!-- 已點踩:藍色背景 -->
                                                <DataTrigger Binding="{Binding RateText}" Value="dislike">
                                                    <Setter Property="Background" Value="#3F51B5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding DisLikeCommand}" MouseAction="LeftClick"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="👎" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                                <Style.Triggers>
                                                    <!-- 已點踩:白色文字 -->
                                                    <DataTrigger Binding="{Binding RateText}" Value="dislike">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 分享按鈕 -->
                        <Button Content="↗️ 分享"
                               Style="{StaticResource ActionButtonStyle}"/>

                        <!-- 儲存按鈕 -->
                        <!--<Button Content="💾 儲存"
                               Style="{StaticResource ActionButtonStyle}"/>-->

                        <!-- 儲存按鈕 - 替換原有的部分 -->
                        <ToggleButton x:Name="playlistBtn"
              Style="{StaticResource SaveToggleButtonStyle}"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=playlistBtn}"
       StaysOpen="False"
       Placement="Bottom"
       PlacementTarget="{Binding ElementName=playlistBtn}"
       PopupAnimation="Fade"
       AllowsTransparency="True">
                            <Border Background="#1F1F1F" 
            BorderBrush="#3F51B5" 
            BorderThickness="2" 
            CornerRadius="8"
            Padding="0"
            Margin="0,8,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                            Opacity="0.5" 
                            ShadowDepth="3" 
                            BlurRadius="10"/>
                                </Border.Effect>

                                <StackPanel MinWidth="280" MaxWidth="400">
                                    <!-- 標題列 -->
                                    <Border Background="#272727" 
                    CornerRadius="8,8,0,0"
                    Padding="16,12">
                                        <TextBlock Text="儲存至播放清單" 
                          FontSize="16" 
                          FontWeight="SemiBold"
                          Foreground="White"/>
                                    </Border>

                                    <!-- 播放清單列表 -->
                                    <ScrollViewer MaxHeight="300" 
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Playlists}"
                            Margin="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Playlist:PlayList Command="{Binding DataContext.SavePlaylistCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                             Margin="0,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- 底部提示 -->
                                    <Border Background="#272727" 
                    CornerRadius="0,0,8,8"
                    Padding="16,10"
                    BorderBrush="#3F3F3F"
                    BorderThickness="0,1,0,0">
                                        <TextBlock Text="點擊可切換播放清單" 
                          FontSize="12" 
                          Foreground="#AAAAAA"
                          TextAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>

                <!-- 分隔線 -->
                <Border Height="1" 
                        Background="#303030"
                        Margin="0,0,0,16"/>

                <!-- 影片描述區域 -->
                <Border Background="#272727" 
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel>
                        <!-- 觀看次數和發布時間 -->
                        <StackPanel Orientation="Horizontal" 
                                   Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource InfoTextStyle}">
                                <Run Text="{Binding ViewCount, StringFormat='{}{0:N0}'}"/>
                                <Run Text="次觀看"/>
                            </TextBlock>
                            <TextBlock Text="{Binding PublishedAt, StringFormat='yyyy/MM/dd'}"
                                      Style="{StaticResource InfoTextStyle}"/>
                        </StackPanel>

                        <!-- 影片描述 -->
                        <TextBlock Text="{Binding VideoDescription}"
                                  Style="{StaticResource DescriptionTextStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 右側:推薦影片列表 (預留) -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" 
                Background="#0F0F0F"
                BorderBrush="#303030"
                BorderThickness="1,0,0,0"
                Padding="16,20">
            <TextBlock Text="推薦影片"
                      Foreground="#AAAAAA"
                      FontSize="14"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"/>
        </Border>
    </Grid>
</Page>
<Page x:Class="Youtube.Views.Pages.VideoPages.VideoSearch"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Youtube.Views.Pages.VideoPages" xmlns:video="clr-namespace:Youtube.Components.VideoCardComponent" xmlns:page="clr-namespace:Youtube.Components.PaginationComponent"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="VideoSearch">

    <!-- 內容區 -->
    <ScrollViewer Grid.Row="2" 
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar"/>
        </ScrollViewer.Resources>

        <StackPanel>
            <StackPanel Visibility="{Binding LoadingPictureVisibility}">
                <!-- 半透明遮罩背景 -->
                <Grid Width="200" Height="200">
                    <Grid.Resources>
                        <!-- 旋轉動畫 -->
                        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
                            <DoubleAnimation 
              Storyboard.TargetName="SpinnerRotate"
              Storyboard.TargetProperty="Angle"
              From="0" To="360" 
              Duration="0:0:1"/>
                        </Storyboard>
                    </Grid.Resources>

                    <!-- 觸發動畫 -->
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
                        </EventTrigger>
                    </Grid.Triggers>

                    <!-- 背景圓 -->
                    <Ellipse Width="80" Height="80"
           Stroke="#E0E0E0" StrokeThickness="8"
           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- 旋轉弧形 -->
                    <Ellipse Width="80" Height="80"
           HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="40" CenterY="40"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4A90D9" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.StrokeThickness>8</Ellipse.StrokeThickness>
                    </Ellipse>

                    <!-- 文字 -->
                    <TextBlock Text="Loading..." 
             HorizontalAlignment="Center" VerticalAlignment="Bottom"
             Margin="0,0,0,20"
             Foreground="#666666" FontSize="14"/>
                </Grid>
            </StackPanel>


            <StackPanel>
                <!-- 影片容器 -->
                <ItemsControl x:Name="VideoContainer" 
                        ItemsSource="{Binding VideoCardContexts}"
                        Padding="24,24,24,40"
                        Background="#0F0F0F">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <video:VideoCard Margin="0,0,16,24" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Visibility="{Binding PageVisibility}">
                    <page:Pagination TotalCount="{Binding DataContext.TotalCount, RelativeSource={RelativeSource AncestorType=Page}}" Command="{Binding DataContext.ChangePaginationIndexCommand, RelativeSource={RelativeSource AncestorType=Page}}" Cursor="Hand"
                               ></page:Pagination>
                </StackPanel>

            </StackPanel>
        </StackPanel>

    </ScrollViewer>
</Page>

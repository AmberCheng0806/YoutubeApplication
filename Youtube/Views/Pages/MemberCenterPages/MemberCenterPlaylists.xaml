<Page
    x:Class="Youtube.Views.Pages.MemberCenterPages.MemberCenterPlaylists"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ComboBox="clr-namespace:Youtube.Components.ComboBoxComponent"
    xmlns:converter="clr-namespace:Youtube.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Youtube.Views.Pages.MemberCenterPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MemberCenterPlaylists"
    d:DesignHeight="900"
    d:DesignWidth="1200"
    Background="#0F0F0F"
    mc:Ignorable="d">

    <Page.Resources>
        <converter:PrivacyConverter x:Key="PrivacyConverter" />
        <converter:InverseEditVisibilityConverter x:Key="InverseEditVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="VisibilityToBoolConverter" />
        <!--  按鈕樣式：主要紅色（刪除）  -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFE14444" />
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFDF1111" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  按鈕樣式：次要灰色（編輯、取消）  -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  按鈕樣式：藍色（儲存）  -->
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1557B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  展開 ToggleButton 樣式  -->
        <Style x:Key="ExpandToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="Content" Value="+" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#272727" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="−" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  文字框樣式  -->
        <Style x:Key="EditTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#272727" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>

        <!--  隱私狀態 Badge  -->
        <Style x:Key="PrivacyBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#272727" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,3" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        Background="#0F0F0F"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  頁面標題  -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF"
                    Text="播放清單" />
                <Border
                    Grid.Row="1"
                    Margin="12,0,0,0"
                    Padding="10,3"
                    VerticalAlignment="Center"
                    Background="#272727"
                    CornerRadius="12">
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="13"
                        Foreground="#AAAAAA"
                        Text="{Binding Playlists.Count, StringFormat={}{0} 個清單}" />
                </Border>
            </StackPanel>

            <!--  播放清單列表標題  -->
            <Border
                Grid.Row="2"
                BorderBrush="#272727"
                BorderThickness="0,0,0,1">
                <Grid Height="40" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Foreground="#606060"
                        Text="播放清單" />

                    <TextBlock
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Foreground="#606060"
                        Text="瀏覽權限" />

                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        Foreground="#606060"
                        Text="建立時間" />

                    <TextBlock
                        Grid.Column="5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="#606060"
                        Text="影片數量" />
                </Grid>
            </Border>

            <!--  播放清單列表  -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding Playlists}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,2"
                            Background="#0F0F0F"
                            BorderBrush="#272727"
                            BorderThickness="0,0,0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#161616" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <!--  用 StackPanel 將主列和子列表分成兩列  -->
                            <StackPanel Orientation="Vertical">

                                <!--  第一列：清單主要資訊  -->
                                <Grid Margin="12,16,12,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>


                                    <!--  展開影片清單  -->
                                    <ToggleButton
                                        Grid.Column="0"
                                        Margin="0,0,6,0"
                                        Command="{Binding ExpandVideosCommand}"
                                        IsChecked="{Binding IsExpanded, Mode=OneWay}"
                                        Style="{StaticResource ExpandToggleButtonStyle}"
                                        ToolTip="展開影片清單"
                                        Visibility="{Binding ExpandVideosBtnVisibility}" />


                                    <!--  播放清單封面  -->
                                    <Border
                                        Grid.Column="1"
                                        Margin="0,0,16,0"
                                        ClipToBounds="True"
                                        CornerRadius="8">
                                        <Grid>
                                            <Image
                                                Height="100"
                                                Source="{Binding PlaylistImg}"
                                                Stretch="UniformToFill" />
                                            <Border
                                                Padding="8,4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="#CC000000"
                                                CornerRadius="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        FontFamily="Segoe UI"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="White"
                                                        Text="{Binding VideosCount}" />
                                                    <TextBlock
                                                        Margin="3,0,0,0"
                                                        FontFamily="Segoe UI"
                                                        FontSize="11"
                                                        Foreground="#CCCCCC"
                                                        Text="部影片" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!--  標題 + 描述  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontFamily="Segoe UI"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="#FFFFFF"
                                            Text="{Binding PlaylistTitle}"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{Binding EditPlaylistModeVisibility, Converter={StaticResource InverseEditVisibilityConverter}}" />
                                        <TextBox
                                            Margin="0,0,0,6"
                                            FontFamily="Segoe UI"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource EditTextBoxStyle}"
                                            Text="{Binding PlaylistTitle}"
                                            Visibility="{Binding EditPlaylistModeVisibility}" />
                                        <TextBlock
                                            MaxHeight="40"
                                            Margin="0,6,0,0"
                                            FontFamily="Segoe UI"
                                            FontSize="13"
                                            Foreground="#AAAAAA"
                                            Text="{Binding PlaylistDescription}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding EditPlaylistModeVisibility, Converter={StaticResource InverseEditVisibilityConverter}}" />
                                        <TextBox
                                            Height="60"
                                            Margin="0,6,0,0"
                                            AcceptsReturn="True"
                                            FontFamily="Segoe UI"
                                            FontSize="13"
                                            Style="{StaticResource EditTextBoxStyle}"
                                            Text="{Binding PlaylistDescription}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding EditPlaylistModeVisibility}" />
                                    </StackPanel>

                                    <!--  隱私狀態  -->
                                    <StackPanel
                                        Grid.Column="3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                        <Border Style="{StaticResource PrivacyBadgeStyle}" Visibility="{Binding EditPlaylistModeVisibility, Converter={StaticResource InverseEditVisibilityConverter}}">
                                            <TextBlock
                                                FontFamily="Segoe UI"
                                                FontSize="12"
                                                Foreground="#AAAAAA"
                                                Text="{Binding PlaylistPrivacyStatus, Converter={StaticResource PrivacyConverter}}" />
                                        </Border>
                                        <!--  播放清單，編輯模式的隱私  -->
                                        <ComboBox:ComboBox
                                            ItemsSource="{Binding Status}"
                                            SelectedValue="{Binding PlaylistPrivacyStatus}"
                                            Visibility="{Binding EditPlaylistModeVisibility}" />
                                    </StackPanel>

                                    <!--  建立日期  -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                        <TextBlock
                                            FontFamily="Segoe UI"
                                            FontSize="13"
                                            Foreground="#AAAAAA"
                                            Text="{Binding PublishedTime, StringFormat=\{0:yyyy年MM月dd日\}}" />
                                    </StackPanel>

                                    <!--  影片數  -->
                                    <StackPanel
                                        Grid.Column="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontFamily="Segoe UI"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="#FFFFFF"
                                            Text="{Binding VideosCount}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontFamily="Segoe UI"
                                            FontSize="11"
                                            Foreground="#606060"
                                            Text="部影片" />
                                    </StackPanel>

                                    <!--  操作按鈕區  -->
                                    <StackPanel
                                        Grid.Column="6"
                                        Margin="16,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">

                                        <!--  刪除  -->
                                        <Button
                                            Width="60"
                                            Height="34"
                                            Margin="0,0,8,0"
                                            Command="{Binding DataContext.DeletePlaylistCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Content="刪除"
                                            Style="{StaticResource PrimaryButtonStyle}" />

                                        <!--  編輯（非編輯模式）  -->
                                        <Button
                                            Width="60"
                                            Height="34"
                                            Command="{Binding EditPlaylistCommand}"
                                            Content="編輯"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Visibility="{Binding EditPlaylistModeVisibility, Converter={StaticResource InverseEditVisibilityConverter}}" />

                                        <!--  儲存（編輯模式）—— 藍色  -->
                                        <Button
                                            Width="60"
                                            Height="34"
                                            Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Content="儲存"
                                            Style="{StaticResource SaveButtonStyle}"
                                            Visibility="{Binding EditPlaylistModeVisibility}" />

                                        <!--  取消（編輯模式）  -->
                                        <Button
                                            Width="60"
                                            Height="34"
                                            Margin="8,0,0,0"
                                            Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Content="取消"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Visibility="{Binding EditPlaylistModeVisibility}" />
                                    </StackPanel>
                                </Grid>

                                <!--  第二列：展開的影片子清單（獨立一列，收合時完全隱藏）  -->
                                <Border
                                    Margin="12,0,12,12"
                                    Background="#161616"
                                    CornerRadius="8"
                                    Visibility="{Binding ExpandVideosVisibility}">
                                    <ItemsControl
                                        Margin="0,4"
                                        AlternationCount="2147483647"
                                        ItemsSource="{Binding PlaylistItemVideos}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,8">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.ClickVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding VideoId}" />
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#1F1F1F" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="32" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="160" />
                                                            <ColumnDefinition Width="160" />
                                                        </Grid.ColumnDefinitions>

                                                        <!--  序號  -->
                                                        <TextBlock Grid.Column="0" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}}" />

                                                        <!--  影片縮圖  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="0,0,12,0"
                                                            ClipToBounds="True"
                                                            CornerRadius="4">
                                                            <Image
                                                                Height="56"
                                                                Source="{Binding VideoImg}"
                                                                Stretch="UniformToFill" />
                                                        </Border>

                                                        <!--  影片標題  -->
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Segoe UI"
                                                            FontSize="13"
                                                            Foreground="#FFFFFF"
                                                            Text="{Binding VideoTitle}"
                                                            TextTrimming="CharacterEllipsis"
                                                            TextWrapping="NoWrap" />

                                                        <!--  頻道名稱  -->
                                                        <TextBlock
                                                            Grid.Column="3"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Segoe UI"
                                                            FontSize="12"
                                                            Foreground="#AAAAAA"
                                                            Text="{Binding ChannelName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <!--  刪除  -->
                                                        <Button
                                                            Grid.Column="4"
                                                            Width="60"
                                                            Height="34"
                                                            Margin="0,0,8,0"
                                                            Command="{Binding DataContext.DeleteVideoCommamd, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Content="刪除"
                                                            Style="{StaticResource PrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>


            <!--  新增播放清單  -->
            <ToggleButton
                Name="PlaylistToggleButton"
                Grid.Row="4"
                Width="140"
                Height="36"
                Margin="0,16,0,0"
                Cursor="Hand">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Bd"
                            Background="#1A73E8"
                            CornerRadius="20">
                            <StackPanel
                                Margin="12,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="+" />
                                <TextBlock
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="新增播放清單" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1557B0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1557B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
            <!--  新增播放清單彈窗  -->
            <Popup
                AllowsTransparency="True"
                IsOpen="{Binding IsChecked, ElementName=PlaylistToggleButton}"
                Placement="Top"
                PlacementTarget="{Binding ElementName=PlaylistToggleButton}"
                StaysOpen="True"
                VerticalOffset="-8">
                <Border
                    Width="320"
                    Padding="20"
                    Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>

                        <!--  標題  -->
                        <TextBlock
                            Margin="0,0,0,16"
                            FontFamily="Segoe UI"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#FFFFFF"
                            Text="新增播放清單" />

                        <!--  清單名稱  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#AAAAAA"
                            Text="名稱" />
                        <TextBox
                            Margin="0,0,0,14"
                            Padding="10,8"
                            Background="#272727"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CaretBrush="White"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Foreground="#FFFFFF"
                            Text="{Binding PlaylistTitle}" />

                        <!--  描述  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#AAAAAA"
                            Text="描述" />
                        <TextBox
                            Height="72"
                            Margin="0,0,0,14"
                            Padding="10,8"
                            AcceptsReturn="True"
                            Background="#272727"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CaretBrush="White"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Foreground="#FFFFFF"
                            Text="{Binding PlaylistDescription}"
                            TextWrapping="Wrap" />

                        <!--  瀏覽權限  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#AAAAAA"
                            Text="瀏覽權限" />
                        <!--  播放清單，新增彈窗的隱私  -->
                        <ComboBox:ComboBox ItemsSource="{Binding Status}" SelectedValue="{Binding PlaylistPrivacy}" />

                        <!--  操作按鈕  -->
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button
                                Width="60"
                                Height="34"
                                Margin="0,0,8,0"
                                Command="{Binding CancelCreatePlaylistCommand}"
                                Content="取消"
                                Cursor="Hand"
                                Style="{StaticResource SecondaryButtonStyle}">
                                <Button.Triggers>
                                    <EventTrigger RoutedEvent="Button.Click">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <BooleanAnimationUsingKeyFrames Storyboard.TargetName="PlaylistToggleButton" Storyboard.TargetProperty="IsChecked">
                                                    <DiscreteBooleanKeyFrame KeyTime="0" Value="False" />
                                                </BooleanAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button
                                Width="60"
                                Height="34"
                                Command="{Binding CreatePlaylistCommand}"
                                Content="確定"
                                Cursor="Hand"
                                Style="{StaticResource SaveButtonStyle}" />
                        </StackPanel>

                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </ScrollViewer>
</Page>
